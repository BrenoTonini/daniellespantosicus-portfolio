import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Olá, Mundo!</h1>
			<p>
				Saudação que não pode faltar, mas agora em português!
			</p>
		</main>
		<Footer />
	</body>
</html>
