---
export const prerender = true;

import AboutHero from '../../components/about/AboutHero.astro';
import AboutText from '../../components/about/AboutText.astro';
import { aboutContent } from '../../i18n/about';
import PageLayout from '../../layouts/PageLayout.astro';

const lang = 'pt-br';
const content = aboutContent[lang];
const site = Astro.site ?? Astro.url.origin;
---

<PageLayout
	title={content.seo.title}
	description={content.seo.description}
	lang={lang}
	canonicalURL={`${site}/pt-br/about/`}
	alternates={[
		{ lang: 'en', href: `${site}/en/about/` },
		{ lang: 'pt-BR', href: `${site}/pt-br/about/` },
	]}
>
	<AboutHero
		image={content.hero.image}
		imageAlt={content.hero.imageAlt}
	/>

	<AboutText content={content.story} />
</PageLayout>
