---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';
import Nav from './Nav.astro';
import LanguagePicker from './LanguagePicker.astro';
import InstagramLogo from '../assets/instagram-logo-outline.svg';
import XLogo from '../assets/x-logo-outline.svg';
import VGenLogo from '../assets/vgen-logo-outline.svg';
import Assinatura from '../assets/assinatura-danielle-spantosicus-preta.png';

const lang = getLangFromUrl(Astro.url);
const translatedPath = useTranslatedPath(lang);
---

<header class="sticky top-0 z-50 bg-white shadow-sm overflow-visible">

    <!-- Linha principal -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">

        <!-- Assinatura — ultrapassa o container -->
        <a href={translatedPath('/')} class="shrink-0 self-stretch flex items-start pt-2">
            <Image
                src={Assinatura}
                alt="Danielle Spantosicus"
                class="h-12 w-auto relative z-10 drop-shadow-sm"
                widths={[200, 400]}
                sizes="(max-width: 640px) 160px, 200px"
                loading="eager"
                format="webp"
            />
        </a>

        <!-- Nav central — só desktop -->
        <div class="hidden sm:flex flex-1 justify-center">
            <Nav />
        </div>

        <!-- Redes sociais + idioma -->
        <div class="flex items-center gap-3 shrink-0">
            <div class="flex items-center gap-2">
                <a href="https://vgen.co/Spantosicus_" target="_blank" rel="noopener noreferrer"
                   class="opacity-60 hover:opacity-100 transition-opacity">
                    <span class="sr-only">VGen profile</span>
                    <img src={VGenLogo.src} alt="" width="20" height="20" />
                </a>
                <a href="https://www.instagram.com/spantosicus/" target="_blank" rel="noopener noreferrer"
                   class="opacity-60 hover:opacity-100 transition-opacity">
                    <span class="sr-only">Instagram</span>
                    <img src={InstagramLogo.src} alt="" width="20" height="20" />
                </a>
                <a href="https://x.com/Spantosicus_" target="_blank" rel="noopener noreferrer"
                   class="opacity-60 hover:opacity-100 transition-opacity">
                    <span class="sr-only">X / Twitter</span>
                    <img src={XLogo.src} alt="" width="20" height="20" />
                </a>
            </div>
            <LanguagePicker />
        </div>
    </div>

    <!-- Segunda linha — nav mobile, sempre visível -->
    <div class="sm:hidden border-t border-gray-100 ">
        <div class="px-4 h-10 flex items-center justify-center">
            <Nav />
        </div>
    </div>

</header>