---
import { languages } from '../i18n/ui';
import { getLangFromUrl, getPathForLang } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const url = Astro.url;

const options = Object.entries(languages).map(([code, label]) => ({
    code,
    label,
    href: getPathForLang(url, code as keyof typeof languages),
    current: code === lang,
}));
---

<div class="lang-picker">
    <select
        id="language-select"
        aria-label="Selecionar idioma"
        class="lang-select"
    >
        {options.map(({ code, label, href, current }) => (
            <option value={href} selected={current}>{code.toUpperCase()}</option>
        ))}
    </select>
    <span class="lang-chevron" aria-hidden="true">▾</span>
</div>

<script>
    const select = document.getElementById('language-select') as HTMLSelectElement;
    select?.addEventListener('change', () => {
        window.location.href = select.value;
    });
</script>

<style>
    .lang-picker {
        position: relative;
        display: inline-flex;
        align-items: center;
        cursor: pointer;
    }

    .lang-select {
        appearance: none;
        background: transparent;
        color: var(--color-muted);
        font-size: 0.75rem;
        border: 1px solid var(--color-border);
        border-radius: 4px;
        padding: 0.2rem 1.25rem 0.2rem 0.4rem;
        cursor: pointer;
        transition: color 150ms ease, border-color 150ms ease;
        cursor: pointer;
    }

    .lang-select:hover {
        color: var(--color-foreground);
        border-color: var(--color-muted);
    }

    .lang-select:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
        border-color: transparent;
    }

    /* Cor das options — limitado pelo browser, mas garante o mínimo */
    .lang-select option {
        background-color: var(--color-surface);
        color: var(--color-foreground);
    }

    .lang-chevron {
        pointer-events: none;
        position: absolute;
        right: 0.375rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.75rem;
        color: var(--color-muted);
    }
</style>