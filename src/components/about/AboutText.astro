---
interface Props {
  content: {
    title?: string;
    paragraphs: readonly string[];
  };
}

const { content } = Astro.props;
---

<section class="px-6 py-14 sm:px-10 sm:py-16 lg:px-16 lg:py-20" aria-label="About story">
  <article class="mx-auto w-full max-w-4xl">
    {content.title && (
      <h2 class="mb-8 font-display text-3xl leading-tight text-(--color-foreground) sm:text-4xl">
        {content.title}
      </h2>
    )}

    <div class="space-y-6 font-sans text-base leading-relaxed text-(--color-foreground-muted) sm:text-lg">
      {content.paragraphs.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </article>
</section>
