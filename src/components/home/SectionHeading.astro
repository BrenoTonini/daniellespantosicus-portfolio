---
interface Props {
  eyebrow?: string;
  heading: string;
  body?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { eyebrow, heading, body, align = 'left', class: className = '' } = Astro.props;
const textAlign = align === 'center' ? 'text-center items-center' : 'text-left items-start';
---

<div class={`flex flex-col gap-3 ${textAlign} ${className}`}>
  {eyebrow && (
    <span class="text-xs font-medium tracking-[0.2em] uppercase text-(--color-primary) font-sans">
      {eyebrow}
    </span>
  )}
  <h2 class="font-display text-4xl md:text-5xl text-(--color-foreground) leading-[1.1] font-normal">
    {heading}
  </h2>
  {body && (
    <p class="text-base text-(--color-foreground-muted) max-w-xl leading-relaxed font-sans mt-1">
      {body}
    </p>
  )}
</div>