---
import type { HomeContent } from '../../i18n/home';
import SectionHeading from './SectionHeading.astro';
import { Image } from 'astro:assets';

interface Props {
  content: HomeContent['featured'];
}

const { content } = Astro.props;
---

<section class="py-24 lg:py-32 px-6 sm:px-10 lg:px-16" aria-label="Featured works">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-8 mb-14">
      <SectionHeading
        eyebrow={content.eyebrow}
        heading={content.heading}
        body={content.body}
      />
      <a
        href={content.ctaHref}
        class="shrink-0 inline-flex items-center gap-2 text-sm font-sans font-medium text-(--color-foreground) border-b border-(--color-foreground) pb-0.5 hover:text-(--color-primary) hover:border-(--color-primary) transition-colors"
      >
        {content.cta}
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="columns-2 lg:columns-3 gap-x-3">
      {content.works.map((work) => (
        <figure class="group relative mb-3 break-inside-avoid overflow-hidden bg-(--color-surface)">
          <Image
            src={work.src}
            alt={work.alt}
            widths={[400, 800, 1200]}
            sizes="(max-width: 1024px) 50vw, 33vw"
            loading="lazy"
            class="block w-full h-auto"
          />

          <figcaption class="absolute inset-x-0 bottom-0 px-3 py-2 bg-(--color-foreground)/60 text-(--color-background) text-xs font-sans translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            {work.caption}
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
